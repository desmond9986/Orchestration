#!/usr/bin/env bash
# end-session — tear down the current orchestration session.
#
# Archives .agents/ into .agents/sessions/<timestamp>/ and kills the tmux session.
#
# Usage:
#   end-session              # archive + kill tmux session
#   end-session --keep-tmux  # snapshot to archive, leave tmux + control plane intact
#   end-session --help
#
# With --keep-tmux the archive is a point-in-time copy; the live roster, inboxes,
# and tasks files stay in place so surviving agents can keep using protocol commands.

set -euo pipefail
: "${ORCHESTRATION_HOME:=$HOME/orchestration}"
export ORCHESTRATION_HOME
source "$ORCHESTRATION_HOME/lib/common.sh"
source "$ORCHESTRATION_HOME/lib/tmux-helpers.sh"

usage() { awk 'NR==1 { next } /^#/ { sub(/^# ?/, ""); print; next } { exit }' "$0"; }

KEEP_TMUX=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --keep-tmux) KEEP_TMUX=1; shift ;;
    -h|--help)   usage; exit 0 ;;
    *) die "unknown flag: $1" ;;
  esac
done

export ORCH_PROJECT="${ORCH_PROJECT:-$PWD}"

[[ -f "$(roster_file)" ]] || die "no active session in $(agents_dir)"

SESSION=$(bash "$ORCHESTRATION_HOME/lib/roster.sh" session)
TS=$(date +"%Y%m%d-%H%M%S")
ARCHIVE_DIR="$(agents_dir)/sessions/$TS-$SESSION"

mkdir -p "$ARCHIVE_DIR"

if [[ "$KEEP_TMUX" -eq 1 ]]; then
  # Snapshot only — copy files so the live control plane stays intact.
  # Agents in the surviving tmux session can continue using roster/protocol/tasks.
  for item in "$(agents_dir)"/*; do
    name=$(basename "$item")
    [[ "$name" == "sessions" ]] && continue
    [[ "$name" == "PROJECT_CONTEXT.md" ]] && continue
    [[ "$name" == "SPECS.md" ]] && continue
    cp -r "$item" "$ARCHIVE_DIR/"
  done
  ok "snapshot archived to $ARCHIVE_DIR (control plane preserved)"
  info "tmux session '$SESSION' kept alive — roster and inbox still active"
else
  # Full teardown — move everything and kill the session.
  for item in "$(agents_dir)"/*; do
    name=$(basename "$item")
    [[ "$name" == "sessions" ]] && continue
    [[ "$name" == "PROJECT_CONTEXT.md" ]] && continue
    [[ "$name" == "SPECS.md" ]] && continue
    mv "$item" "$ARCHIVE_DIR/"
  done
  ok "archived to $ARCHIVE_DIR"
  kill_session "$SESSION"
  ok "killed tmux session: $SESSION"
fi
