#!/usr/bin/env bash
# orch-preflight — quick local validation before starting orchestration.
#
# Usage:
#   orch-preflight
#   orch-preflight --repair
#   ORCH_PROJECT=/path/to/project orch-preflight

set -euo pipefail

: "${ORCHESTRATION_HOME:=$HOME/orchestration}"
source "$ORCHESTRATION_HOME/lib/common.sh"

PROJECT="${ORCH_PROJECT:-$PWD}"
AGENTS_DIR="$PROJECT/.agents"
ROSTER="$AGENTS_DIR/roster.json"
REPAIR=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repair) REPAIR=1; shift ;;
    -h|--help)
      awk 'NR==1 { next } /^#/ { sub(/^# ?/, ""); print; next } { exit }' "$0"
      exit 0
      ;;
    *) die "unknown flag: $1" ;;
  esac
done

missing=0
warnings=0
repaired=0

repair_required_files() {
  ensure_agents_dir
  if [[ ! -f "$AGENTS_DIR/tasks.json" ]]; then
    jq -n '{tasks:[]}' > "$AGENTS_DIR/tasks.json"
    ok "repair: created tasks.json"
    repaired=$((repaired+1))
  fi
  if [[ ! -f "$AGENTS_DIR/tasks.notify.json" ]]; then
    jq -n '{last:{}}' > "$AGENTS_DIR/tasks.notify.json"
    ok "repair: created tasks.notify.json"
    repaired=$((repaired+1))
  fi
}

check_cmd() {
  local c="$1"
  if command -v "$c" >/dev/null 2>&1; then
    ok "dependency: $c"
  else
    warn "missing dependency: $c"
    missing=1
  fi
}

check_hasher() {
  if command -v shasum >/dev/null 2>&1 \
    || command -v sha1sum >/dev/null 2>&1 \
    || command -v cksum >/dev/null 2>&1; then
    ok "dependency: hasher"
  else
    warn "missing dependency: pane hasher (shasum/sha1sum/cksum)"
    missing=1
  fi
}

check_roster_integrity() {
  [[ -f "$ROSTER" ]] || { warn "no roster yet at $ROSTER"; warnings=$((warnings+1)); return 0; }
  if ! jq empty "$ROSTER" >/dev/null 2>&1; then
    warn "roster.json is not valid JSON"
    missing=1
    return 0
  fi

  local dup
  dup=$(jq -r '[.agents[] | select(.status=="active") | .id] | group_by(.)[] | select(length>1) | .[0]' "$ROSTER" \
    | tr '\n' ' ' | sed 's/[[:space:]]*$//')
  if [[ -n "$dup" ]]; then
    warn "duplicate agent id(s): $dup"
    missing=1
  else
    ok "roster integrity: unique agent ids"
  fi
}

tmux_pane_exists() {
  local target="$1"
  tmux display-message -p -t "$target" '#{pane_id}' >/dev/null 2>&1
}

tmux_pane_agent_id() {
  local target="$1"
  tmux display-message -p -t "$target" '#{@orch_agent_id}' 2>/dev/null || true
}

tmux_canonical_target() {
  local target="$1"
  tmux display-message -p -t "$target" '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null || true
}

find_pane_by_agent_id() {
  local session="$1" id="$2"
  tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}	#{@orch_agent_id}' 2>/dev/null \
    | awk -F'\t' -v s="$session" -v id="$id" '$1 ~ "^" s ":" && $2 == id { print $1 }'
}

repair_roster_targets() {
  [[ "$REPAIR" -eq 1 ]] || return 0
  [[ -f "$ROSTER" ]] || return 0
  jq empty "$ROSTER" >/dev/null 2>&1 || return 0

  local session
  session=$(jq -r '.session // ""' "$ROSTER")
  [[ -n "$session" ]] || return 0

  local changed=0 tmp
  while IFS=$'\t' read -r id target; do
    [[ -n "$id" ]] || continue
    local current_meta canon recovered count
    if tmux_pane_exists "$target"; then
      current_meta=$(tmux_pane_agent_id "$target")
      canon=$(tmux_canonical_target "$target")
      if [[ "$current_meta" == "$id" && -n "$canon" ]]; then
        if [[ "$canon" != "$target" ]]; then
          tmp=$(mktemp)
          jq --arg id "$id" --arg target "$canon" --arg t "$(ts)" \
            '(.agents[] | select(.id==$id and .status=="active") | .target) = $target |
             (.agents[] | select(.id==$id and .status=="active") | .retargeted) = $t' \
            "$ROSTER" > "$tmp" && mv "$tmp" "$ROSTER"
          ok "repair: canonicalized $id target $target -> $canon"
          changed=$((changed+1))
        fi
        continue
      fi
    fi

    recovered=$(find_pane_by_agent_id "$session" "$id" | sed '/^$/d')
    count=$(printf "%s\n" "$recovered" | sed '/^$/d' | wc -l | tr -d ' ')
    if [[ "$count" == "1" ]]; then
      local new_target
      new_target=$(printf "%s\n" "$recovered" | sed -n '1p')
      tmp=$(mktemp)
      jq --arg id "$id" --arg target "$new_target" --arg t "$(ts)" \
        '(.agents[] | select(.id==$id and .status=="active") | .target) = $target |
         (.agents[] | select(.id==$id and .status=="active") | .retargeted) = $t' \
        "$ROSTER" > "$tmp" && mv "$tmp" "$ROSTER"
      ok "repair: retargeted $id $target -> $new_target"
      changed=$((changed+1))
    elif [[ "$count" != "0" ]]; then
      warn "repair: ambiguous panes for $id; leaving target unchanged"
      warnings=$((warnings+1))
    else
      # No live pane found — mark the entry as left so it stops polluting checks.
      tmp=$(mktemp)
      jq --arg id "$id" --arg t "$(ts)" \
        '(.agents[] | select(.id==$id and .status=="active") | .status) = "left" |
         (.agents[] | select(.id==$id and .status=="left") | .left) = $t' \
        "$ROSTER" > "$tmp" && mv "$tmp" "$ROSTER"
      ok "repair: marked dead agent $id as left (pane gone)"
      changed=$((changed+1))
    fi
  done < <(jq -r '.agents[] | select(.status=="active") | [.id,.target] | @tsv' "$ROSTER")

  if [[ "$changed" -gt 0 ]]; then
    repaired=$((repaired+changed))
  fi
}

check_skip_env() {
  local found=""
  while IFS='=' read -r k v; do
    case "$k" in
      ORCH_SKIP_PERMISSIONS|ORCH_SKIP_PERMISSIONS_*)
        if [[ "${v:-0}" == "1" ]]; then
          found+="$k "
        fi
        ;;
    esac
  done < <(env)
  if [[ -n "$found" ]]; then
    warn "permission bypass env is enabled: $found"
    warn "for safer public runs, unset these or avoid --respect-env-skip-permissions"
    warnings=$((warnings+1))
  else
    ok "permission bypass env: off"
  fi
}

info "preflight project: $PROJECT"
if [[ "$REPAIR" -eq 1 ]]; then
  repair_required_files
fi
check_cmd tmux
check_cmd jq
check_hasher
check_roster_integrity
repair_roster_targets
check_skip_env

if [[ "$missing" -eq 1 ]]; then
  printf "\nOverall: FAIL\n"
  exit 1
fi

if [[ "$warnings" -gt 0 ]]; then
  if [[ "$REPAIR" -eq 1 ]]; then
    printf "Repairs applied: %s\n" "$repaired"
  fi
  printf "\nOverall: PASS_WITH_WARNINGS\n"
  exit 0
fi

if [[ "$REPAIR" -eq 1 ]]; then
  printf "Repairs applied: %s\n" "$repaired"
fi
printf "\nOverall: PASS\n"
