#!/usr/bin/env bash
# orch-watch ŌĆö actionable live dashboard (inbox backlog + work signals).
#
# Refreshes every N seconds (default 2). Ctrl-C to exit.
#
# Usage:
#   orch-watch                     # actionable summary only
#   orch-watch 3                   # refresh every 3s
#   orch-watch 2 8                 # (legacy) also show pane tails, 8 lines
#   orch-watch --pane-tail 8       # show pane tails explicitly
#   orch-watch --help

set -euo pipefail
: "${ORCHESTRATION_HOME:=$HOME/orchestration}"
export ORCHESTRATION_HOME
source "$ORCHESTRATION_HOME/lib/common.sh"

usage() { awk 'NR==1 { next } /^#/ { sub(/^# ?/, ""); print; next } { exit }' "$0"; }

INTERVAL=2
PANE_LINES=0

case "${1:-}" in -h|--help) usage; exit 0 ;; esac

if [[ $# -gt 0 && "${1:-}" != "--pane-tail" ]]; then
  INTERVAL="${1:-2}"
  shift || true
fi
[[ "$INTERVAL" =~ ^[0-9]+$ ]] || die "invalid interval: $INTERVAL"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --pane-tail)
      PANE_LINES="${2:-5}"
      [[ "$PANE_LINES" =~ ^[0-9]+$ ]] || die "invalid --pane-tail value"
      shift 2
      ;;
    *)
      # Backward compatibility: second positional argument = pane lines.
      if [[ "$1" =~ ^[0-9]+$ && "$PANE_LINES" -eq 0 ]]; then
        PANE_LINES="$1"
        shift
      else
        die "unknown option: $1"
      fi
      ;;
  esac
done

export ORCH_PROJECT="$PWD"
[[ -f "$(roster_file)" ]] || die "no session in $(agents_dir)"

hr() {
  local cols
  cols="$(tput cols 2>/dev/null || echo 100)"
  printf '%*s\n' "$cols" '' | tr ' ' 'ŌöĆ'
}

inbox_unread() {
  local id="$1"
  local p
  p="$(inbox_dir)/$id.jsonl"
  [[ -f "$p" ]] || { echo 0; return; }
  wc -l < "$p" 2>/dev/null | tr -d ' ' || echo 0
}

last_header_to() {
  local id="$1"
  grep -E "\\] .* ŌåÆ ${id}  \\[[A-Z_]+\\]" "$(bus_file)" 2>/dev/null | tail -1 || true
}

last_header_from() {
  local id="$1"
  grep -E "\\] ${id} ŌåÆ .* \\[[A-Z_]+\\]" "$(bus_file)" 2>/dev/null | tail -1 || true
}

extract_type() {
  printf "%s" "$1" | sed -nE 's/.*\[([A-Z_]+)\].*/\1/p'
}

extract_time() {
  printf "%s" "$1" | sed -nE 's/^\[([0-9:]+)\].*/\1/p'
}

signal_for_agent() {
  local id="$1" target="$2" unread="$3" last_to="$4" last_from="$5"
  if ! tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null | grep -Fxq "$target"; then
    echo "UNREACHABLE"
    return
  fi
  if (( unread > 0 )); then
    echo "WAITING_INBOX"
    return
  fi
  local tfrom tto
  tfrom=$(extract_type "$last_from")
  tto=$(extract_type "$last_to")
  if [[ "$tfrom" == "DONE" ]]; then
    echo "DONE_REPORTED"
  elif [[ "$tfrom" == "BLOCKED" ]]; then
    echo "BLOCKED_REPORTED"
  elif [[ "$tfrom" == "STATUS" && "$tto" == "STATUS" ]]; then
    echo "STATUS_LOOP_RISK"
  else
    echo "IDLE_OR_WORKING"
  fi
}

render() {
  clear
  printf "${C_BOLD}orchestration watch${C_RESET} ${C_DIM}(%s refresh=%ss)${C_RESET}\n" \
    "$(date +%H:%M:%S)" "$INTERVAL"
  hr

  printf "${C_BOLD}Agent Signals${C_RESET}\n"
  printf "%-14s %-12s %-6s %-17s %-8s %-10s %-10s\n" "agent" "role" "unread" "signal" "target" "lastŌåÆtime" "lastŌåÉtime"
  hr

  jq -r '.agents[] | select(.status=="active") | "\(.id)\t\(.role)\t\(.target)"' "$(roster_file)" \
    | while IFS=$'\t' read -r id role target; do
        local unread last_to last_from sig
        unread=$(inbox_unread "$id")
        [[ "$unread" =~ ^[0-9]+$ ]] || unread=0
        last_to=$(last_header_to "$id")
        last_from=$(last_header_from "$id")
        sig=$(signal_for_agent "$id" "$target" "$unread" "$last_to" "$last_from")
        printf "%-14s %-12s %-6s %-17s %-8s %-10s %-10s\n" \
          "$id" "$role" "$unread" "$sig" "${target##*:}" \
          "$(extract_time "$last_to")" "$(extract_time "$last_from")"
      done
  echo ""

  printf "${C_BOLD}Recent Bus${C_RESET}\n"
  hr
  tail -8 "$(bus_file)" 2>/dev/null || echo "(empty)"

  if (( PANE_LINES > 0 )); then
    echo ""
    printf "${C_BOLD}Pane Tails${C_RESET} ${C_DIM}(last %s lines)${C_RESET}\n" "$PANE_LINES"
    hr
    jq -r '.agents[] | select(.status=="active") | "\(.id)\t\(.target)"' "$(roster_file)" \
      | while IFS=$'\t' read -r id target; do
          printf "${C_BLUE}Ō¢Ė %s${C_RESET} ${C_DIM}(%s)${C_RESET}\n" "$id" "$target"
          if tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null | grep -Fxq "$target"; then
            tmux capture-pane -t "$target" -p 2>/dev/null | grep -v '^$' | tail -n "$PANE_LINES" | sed 's/^/  Ōöé /'
          else
            printf "  ${C_YELLOW}Ōöé (pane not found)${C_RESET}\n"
          fi
          echo ""
        done
  fi
}

trap "clear; exit 0" INT TERM
while true; do
  render
  sleep "$INTERVAL"
done
