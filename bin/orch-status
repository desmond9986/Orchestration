#!/usr/bin/env bash
# orch-status — show the live state of the current orchestration session.
#
# Usage:
#   orch-status                  # roster + last 20 bus messages
#   orch-status --bus            # print the full message bus
#   orch-status --follow         # tail -f the message bus (live view of ALL messages)
#   orch-status --status         # summary status board (one-line events)
#   orch-status --follow-status  # tail -f the status board
#   orch-status --roster         # just the roster (who's active)
#   orch-status --inbox <id>     # peek an agent's unread inbox
#   orch-status --log            # show log (errors, delivery failures)

set -euo pipefail
: "${ORCHESTRATION_HOME:=$HOME/orchestration}"
export ORCHESTRATION_HOME
source "$ORCHESTRATION_HOME/lib/common.sh"

usage() { awk 'NR==1 { next } /^#/ { sub(/^# ?/, ""); print; next } { exit }' "$0"; }

export ORCH_PROJECT="$PWD"

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  --bus)
    [[ -f "$(bus_file)" ]] || die "no session here"
    cat "$(bus_file)"
    ;;
  --follow)
    [[ -f "$(bus_file)" ]] || die "no session here"
    info "following message bus (Ctrl-C to stop)"
    tail -f "$(bus_file)"
    ;;
  --status)
    [[ -f "$(status_file)" ]] || die "no session here"
    cat "$(status_file)"
    ;;
  --follow-status)
    [[ -f "$(status_file)" ]] || die "no session here"
    tail -f "$(status_file)"
    ;;
  --roster)
    [[ -f "$(roster_file)" ]] || die "no session here"
    bash "$ORCHESTRATION_HOME/lib/roster.sh" list-active
    ;;
  --inbox)
    ID="${2:?id required}"
    bash "$ORCHESTRATION_HOME/lib/protocol.sh" peek-inbox "$ID"
    ;;
  --log)
    [[ -f "$(log_file)" ]] || die "no log"
    cat "$(log_file)"
    ;;
  "")
    [[ -f "$(roster_file)" ]] || die "no session in $(agents_dir)"
    printf '%s\n' "${C_BOLD}Roster:${C_RESET}"
    bash "$ORCHESTRATION_HOME/lib/roster.sh" list-active
    echo ""
    printf '%s\n' "${C_BOLD}Recent bus activity (last 20 lines):${C_RESET}"
    tail -20 "$(bus_file)" 2>/dev/null || echo "(none)"
    echo ""
    printf '%s\n' "${C_DIM}tip: run 'orch-status --follow' to watch live${C_RESET}"
    ;;
  *) die "unknown option: $1 (try: orch-status --help)" ;;
esac
